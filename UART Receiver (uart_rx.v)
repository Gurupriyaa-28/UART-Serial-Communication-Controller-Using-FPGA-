
module uart_rx(
    input clk,
    input reset,
    input tick,
    input rx,
    output reg [7:0] data_out,
    output reg rx_done
);

reg [3:0] state;
reg [2:0] bit_index;
reg [7:0] data_buf;

always @(posedge clk or posedge reset)
begin
    if(reset)
    begin
        state <= 0;
        bit_index <= 0;
        rx_done <= 0;
    end
    else
    begin
        if(tick)
        begin
            case(state)

            0:
            begin
                rx_done <= 0;

                if(rx == 0)
                    state <= 1;
            end

            1:
            begin
                data_buf[bit_index] <= rx;

                if(bit_index == 7)
                    state <= 2;
                else
                    bit_index <= bit_index + 1;
            end

            2:
            begin
                data_out <= data_buf;
                rx_done <= 1;
                bit_index <= 0;
                state <= 0;
            end

            endcase
        end
    end
end

endmodule
