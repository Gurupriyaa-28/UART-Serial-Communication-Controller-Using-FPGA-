module uart_tx(
    input clk,
    input reset,
    input tick,
    input tx_start,
    input [7:0] data_in,
    output reg tx,
    output reg busy
);

reg [3:0] state;
reg [7:0] data_buf;
reg [2:0] bit_index;

always @(posedge clk or posedge reset)
begin
    if(reset)
    begin
        tx <= 1'b1;
        busy <= 0;
        state <= 0;
        bit_index <= 0;
    end
    else
    begin
        if(tick)
        begin
            case(state)

            0:
            begin
                tx <= 1'b1;
                busy <= 0;

                if(tx_start)
                begin
                    data_buf <= data_in;
                    busy <= 1;
                    state <= 1;
                end
            end

            1:
            begin
                tx <= 1'b0;
                state <= 2;
                bit_index <= 0;
            end

            2:
            begin
                tx <= data_buf[bit_index];

                if(bit_index == 7)
                    state <= 3;
                else
                    bit_index <= bit_index + 1;
            end

            3:
            begin
                tx <= 1'b1;
                state <= 0;
            end

            endcase
        end
    end
end

endmodule
